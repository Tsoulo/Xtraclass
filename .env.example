# ===========================================
# XtraClass.ai Environment Configuration
# ===========================================
# Copy this file to .env and fill in your actual values
# For Replit: Use Secrets tab instead (🔒 icon in Tools)
# ===========================================

# ===========================================
# REQUIRED - Database
# ===========================================
# PostgreSQL connection string (from Neon, Railway, or other provider)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ===========================================
# REQUIRED - Paystack Payment Gateway
# ===========================================
# Get these from: https://dashboard.paystack.com/#/settings/developer
# NOTE: Use TEST keys for development, LIVE keys for production

# Paystack Secret Key (sk_test_xxx for testing, sk_live_xxx for production)
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here

# Paystack Public Key (pk_test_xxx for testing, pk_live_xxx for production)
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here

# Paystack Premium Plan Code (from your Paystack subscription plan)
# You can find this in your Paystack dashboard under Plans & Subscriptions
PREMIUM_PLAN=PLN_xxxxxxxxxx

# ===========================================
# OPTIONAL - Application URLs
# ===========================================
# Production URL (used for parent consent links and email links)
# Leave empty for development - will auto-detect from REPLIT_DEV_DOMAIN
# PUBLIC_APP_URL=https://xtraclass.ai

# Replit Development Domain (automatically provided by Replit)
# Do NOT set this manually - Replit provides it automatically
# REPLIT_DEV_DOMAIN=your-repl-name.replit.dev

# Frontend URL for emails (defaults to PUBLIC_APP_URL if not set)
# FRONTEND_URL=https://xtraclass.ai

# ===========================================
# OPTIONAL - OpenAI (AI Features)
# ===========================================
# Required for AI-powered grading, feedback, tutorials, and chat
# Get your key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# OPTIONAL - SendGrid (Email Notifications)
# ===========================================
# Required for email notifications (welcome emails, homework reminders, etc.)
# Get your key from: https://app.sendgrid.com/settings/api_keys
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxx

# Email sender address (defaults to noreply@xtraclass.ai)
# FROM_EMAIL=noreply@xtraclass.ai

# ===========================================
# OPTIONAL - Security & Configuration
# ===========================================
# JWT Secret for token signing (auto-generated if not provided)
# Generate a random secret: openssl rand -base64 32
# JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Environment mode
# Values: development, production, test
# NODE_ENV=development

# Payment buffer time in minutes (for webhook processing grace period)
# Development: 30 minutes (for testing)
# Production: 7200 minutes (5 days recommended)
PAYMENT_BUFFER_MINUTES=30

# ===========================================
# QUICK START GUIDE
# ===========================================
# 
# 1. DEVELOPMENT (Replit):
#    - Use Secrets tab (🔒) to set: DATABASE_URL, PAYSTACK_SECRET_KEY, 
#      PAYSTACK_PUBLIC_KEY, PREMIUM_PLAN, OPENAI_API_KEY (optional)
#    - REPLIT_DEV_DOMAIN is auto-provided by Replit
#
# 2. DEVELOPMENT (Local):
#    - Copy this file: cp .env.example .env
#    - Fill in all REQUIRED values in .env
#    - Add OPTIONAL values as needed
#
# 3. PRODUCTION:
#    - Set PUBLIC_APP_URL=https://xtraclass.ai
#    - Use LIVE Paystack keys (sk_live_xxx, pk_live_xxx)
#    - Set PAYMENT_BUFFER_MINUTES=7200
#    - Add all other required environment variables
#
# ===========================================
# SECURITY NOTES
# ===========================================
# - NEVER commit .env file to git (already in .gitignore)
# - Use separate keys for development and production
# - Rotate keys regularly
# - Keep secrets secure and never share them
# ===========================================
