    "csv-parse": "^5.6.0",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.6.0",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "file-type": "^20.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
